// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Inspection {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())

  // Header details
  vehicleRegistration   String
  vehicleMake           String?
  edmReading            String?
  trailerRegistration   String?
  driverName            String
  driverAge             String?
  licenceExpiryDate     String?
  tripFrom              String?
  tripTo                String?
  consignee             String?
  cargoType             String?
  hazmat                Boolean  @default(false)

  // Post loading
  loadSecured           String?  // 'yes' | 'no' | null
  driverCellPhone       String?

  // Comments
  driverComments        String?
  inspectorComments     String?

  // Sign-off
  inspectedBySignature  String?
  inspectedByDate       String?
  approvedBySignature   String?
  approvedByDate        String?
  approvedByTime        String?

  // Related items
  items                 InspectionItem[]
}

model InspectionItem {
  id           String      @id @default(cuid())
  inspectionId String
  itemKey      String      // The checklist item key (e.g., 'tire-pressure' or 'tire-condition__horse')
  status       String?     // 'ok' | 'attention' | 'na'
  inspection   Inspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([itemKey])
}
